import streamlit as st
import sqlite3
import pandas as pd
import requests
import re

# --- CONFIGURATION ---
DB_NAME = "lobbying.db"
# How many records to pull automatically on load (max 200 is good for speed)
AUTO_SYNC_LIMIT = 200

# --- DATABASE SETUP ---
def init_db():
    conn = sqlite3.connect(DB_NAME)
    conn.execute('''CREATE TABLE IF NOT EXISTS filings 
                    (uuid TEXT PRIMARY KEY, reg_name TEXT, client_name TEXT, 
                     amount REAL, year INTEGER, period TEXT, issues TEXT, 
                     bills TEXT, is_current BOOLEAN)''')
    conn.execute('''CREATE TABLE IF NOT EXISTS lobbyists 
                    (uuid TEXT, name TEXT, position TEXT, is_revolving BOOLEAN, tier TEXT)''')
    conn.commit()
    return conn

def classify_revolving_door(text):
    if not text: return False, "None"
    high_tier = r'(Senator|Member|Representative|Congress|Secretary|Director|General Counsel)'
    mid_tier = r'(Chief of Staff|Counsel|Advisor|Legislative Director|LD|COS)'
    if re.search(high_tier, text, re.I): return True, "High-Level"
    if re.search(mid_tier, text, re.I): return True, "Mid-Level"
    return True, "Staff"

# This function is "cached." It will only run once per hour (3600 seconds),
# preventing the app from being throttled by the Senate's 15-request-per-minute limit.
@st.cache_data(ttl=3600, show_spinner="Updating lobbying database from Senate API...")
def auto_sync():
    conn = sqlite3.connect(DB_NAME)
    API_URL = "https://lda.gov/api/v1/filings/"
    try:
        res = requests.get(API_URL, params={'ordering': '-dt_posted', 'page_size': AUTO_SYNC_LIMIT}).json()
        records = res.get('results', [])
        for f in records:
            uuid = f['filing_uuid']
            conn.execute("UPDATE filings SET is_current=0 WHERE client_name=? AND year=? AND period=?", 
                         (f['client']['name'], f['filing_year'], f['filing_period']))
            all_issues = " ".join([a.get('specific_lobbying_issues', '') or '' for a in f.get('lobbying_activities', [])])
            bills = ", ".join(list(set(re.findall(r'(?:S\.|H\.R\.)\s*\d+', all_issues))))
            conn.execute("INSERT OR REPLACE INTO filings VALUES (?,?,?,?,?,?,?,?,?)",
                         (uuid, f['registrant']['name'], f['client']['name'], f['amount'], 
                          f['filing_year'], f['filing_period'], all_issues, bills, 1))
            for act in f.get('lobbying_activities', []):
                for lob in act.get('lobbyists', []):
                    is_rev, tier = classify_revolving_door(lob['covered_position'])
                    conn.execute("INSERT INTO lobbyists (uuid, name, position, is_revolving, tier) VALUES (?,?,?,?,?)", 
                                 (uuid, f"{lob['first_name']} {lob['last_name']}", lob['covered_position'], is_rev, tier))
        conn.commit()
        return f"Database updated with latest {len(records)} filings."
    except Exception as e:
        return f"Automatic sync paused (Reason: {e})"
    finally:
        conn.close()

# --- UI CODE ---
st.set_page_config(page_title="InfluenceTracker", layout="wide")
st.title("🏛️ Public Citizen Lobbying Research Portal")

# 1. Start Database
init_db()

# 2. Silent Auto-Sync (Runs on load, but only hits the API once per hour)
sync_status = auto_sync()

# --- SEARCH PANEL ---
st.write("### 🔍 Search & Export")
with st.form("search_form"):
    col1, col2, col3 = st.columns(3)
    with col1:
        q_client = st.text_input("Client Name", placeholder="e.g. Amazon")
    with col2:
        q_bill = st.text_input("Bill Number", placeholder="e.g. S.1234")
    with col3:
        rev_only = st.checkbox("Revolving Door Lobbyists Only")
    
    submit_button = st.form_submit_button("Run Research Search")

# --- RESULTS ---
conn = sqlite3.connect(DB_NAME)
if submit_button:
    query = """
        SELECT f.client_name as Client, f.reg_name as Firm, f.amount as Spend, 
               f.year as Year, f.period as Qtr, f.bills as Bills, 
               group_concat(l.name || ' (' || l.tier || ')') as Lobbyists
        FROM filings f
        LEFT JOIN lobbyists l ON f.uuid = l.uuid
        WHERE f.is_current = 1
    """
    params = []
    if q_client:
        query += " AND f.client_name LIKE ?"
        params.append(f'%{q_client}%')
    if q_bill:
        query += " AND f.bills LIKE ?"
        params.append(f'%{q_bill}%')
    if rev_only:
        query += " AND l.is_revolving = 1"
        
    query += " GROUP BY f.uuid ORDER BY f.amount DESC"
    
    df = pd.read_sql(query, conn, params=params)

    if not df.empty:
        st.success(f"Displaying {len(df)} matching records found in local database.")
        st.dataframe(df, use_container_width=True)
        csv = df.to_csv(index=False).encode('utf-8')
        st.download_button("📥 Download Analysis CSV", data=csv, file_name="lobbying_export.csv")
    else:
        st.warning("No matches found. Try clearing filters or wait for the next auto-sync.")
else:
    # Default view: Show the most recent 10 records so the app isn't blank
    st.write("Latest filings synced (top 10):")
    recent_df = pd.read_sql("SELECT client_name, reg_name, amount, year, period FROM filings WHERE is_current=1 ORDER BY uuid DESC LIMIT 10", conn)
    st.table(recent_df)

st.divider()
st.caption(f"Status: {sync_status} | Data refreshed every 60 minutes.")
conn.close()
